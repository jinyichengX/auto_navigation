<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:macro name = "drive_wheel_xacro" params = "wheel_name xyz">
        <link name = "${wheel_name}_link">
            <!-- 部件的外观描述 -->
            <visual>
                <!-- 相对于它所属 link 原点的位置偏移 -->
                <!-- 1.5708弧度，表示绕X轴旋转90度，把竖直的圆柱体放平成轮子 -->
                <origin xyz="0 0 0" rpy="1.5708 0 0"/> 
                <!-- 几何形状 -->
                <geometry>
                    <cylinder radius="0.032" length="0.04"/>   <!-- 半径0.032m 高0.04m -->
                </geometry>
                <!-- 材质颜色 -->
                <material name="yellow">
                    <color rgba="1 1 0 0.8"/>    <!-- 红 绿 蓝 透明度，范围0~1 -->
                </material>
            </visual>
        </link>
        <joint name = "${wheel_name}_joint" type = "continuous">
            <parent link = "base_link"/>
            <child link = "${wheel_name}_link"/>
            <origin xyz="${xyz}" rpy="0 0 0"/> <!-- child(${${wheel_name}_link) 相对于 parent(base_link) 的偏移 -->
            <axis xyz="0 1 0"/> <!-- 轴向为y轴 -->
        </joint>
    </xacro:macro>
</robot>